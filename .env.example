# =========================
# NIVRAN — Environment Template (NO SECRETS)
# Copy to .env.local and fill in real values.
# =========================

# --- Database (Neon/Postgres) ---
# POOLED connection (often host contains "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&channel_binding=require"

# UNPOOLED / direct connection (often host WITHOUT "-pooler")
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full&channel_binding=require"

# --- App URLs ---
# Local dev base URL
APP_BASE_URL="http://localhost:3000"

# Public site URL (used for metadataBase / canonical, etc.)
NEXT_PUBLIC_SITE_URL="https://www.nivran.com"

# WhatsApp number (digits only, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER="962791752686"

# --- Admin ---
# Protect admin pages / API (set a strong value in .env.local and in Vercel)
ADMIN_TOKEN="8b07fe1fbb04b7a8bcfec557ac4f7e130dee1fda7b571b3e"

# --- PayTabs ---
# PayTabs base (example for Jordan; confirm in your PayTabs account)
PAYTABS_API_BASE_URL="https://secure-jordan.paytabs.com"
PAYTABS_PROFILE_ID="YOUR_PROFILE_ID"
PAYTABS_SERVER_KEY="YOUR_SERVER_KEY"
PAYTABS_CLIENT_KEY="YOUR_CLIENT_KEY"

# If your code uses these callback/return URLs, set real values in .env.local / Vercel
PAYTABS_CALLBACK_URL="http://localhost:3000/api/paytabs/callback"
PAYTABS_RETURN_URL="http://localhost:3000/en/checkout?result=paytabs"

# --- Flat shipping (public) ---
NEXT_PUBLIC_FLAT_SHIPPING_JOD="3.5"

# --- Optional: WhatsApp template metadata (public) ---
NEXT_PUBLIC_WA_PHONE_E164="962791752686"
NEXT_PUBLIC_WA_MESSAGE_TEMPLATE_ID="whatsapp_business_management_1"
NEXT_PUBLIC_WA_MESSAGE_TEMPLATE_NAME="order_notification"
NEXT_PUBLIC_WA_MESSAGE_TEMPLATE_LANGUAGE="en"
